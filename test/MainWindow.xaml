<Window x:Class="test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ReTouch Test" Height="300" Width="420">
    <StackPanel Margin="20">
        <Button Content="Open Driver" Height="40" Click="Open_Click"/>
        <Button Content="Touch Down" Height="40" Margin="0,10,0,0" Click="Down_Click"/>
        <Button Content="Touch Move" Height="40" Margin="0,10,0,0" Click="Move_Click"/>
        <Button Content="Touch Up" Height="40" Margin="0,10,0,0" Click="Up_Click"/>
        <TextBlock x:Name="LogText" Margin="0,20,0,0" TextWrapping="Wrap"/>
    </StackPanel>
</Window>